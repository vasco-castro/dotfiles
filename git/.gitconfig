# ~/.gitconfig

[user]
    name = Your Name
    email = your@email.com

[core]
    editor = vim
    excludesfile = ~/.gitignore_global
    autocrlf = input

[color]
    ui = auto

[push]
    default = simple

[pull]
    rebase = false

[alias]
    st = status
    co = checkout
    br = branch
    ci = commit
    lg = log --oneline --graph --decorate --all
    undo = reset --soft HEAD~1
    unstage = reset HEAD --
